# =============================================================================
# Hermes Agent — .gitignore
# =============================================================================

# Local environment / secrets — NEVER commit these
.env
.env.local
.env.*.local
.env.production
.env.development

# SQLite temporary files, journals, and WAL files
*.db
*.db-journal
*.db-wal
*.db-shm

# Python compilation and cache files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Node.js dependencies (if using the dashboard locally)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# macOS / OS / IDE artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Docker build cache and local volumes/mounts
.dockerignore
.hermes/
hermes_data/
data/

# Logs
*.log
