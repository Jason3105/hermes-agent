# =============================================================================
# Hermes Agent — Local Environment Template
# =============================================================================
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — NEVER commit secrets to Git.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=hermes-state

# --- Hermes API Server -------------------------------------------------------
# A strong random string used as the Bearer token for the API server.
# Generate one with: openssl rand -hex 32
API_SERVER_KEY=your-strong-random-api-key

# --- LLM Provider: OpenRouter ------------------------------------------------
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# --- LLM Provider: Groq (Optional) -------------------------------------------
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key

# Model selection is handled dynamically inside the agent — no env var needed.
# On first run: use `hermes model` or the Hermes dashboard to pick your model.
# Your choice is saved to config.yaml, which is backed up to Supabase Storage
# and restored on every container restart — so it persists across redeploys.

# --- Messenger Platform Tokens (optional) ------------------------------------
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# --- Backup Settings ---------------------------------------------------------
BACKUP_INTERVAL_MINS=5
